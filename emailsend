import smtplib
from email.message import EmailMessage

def send_notification(visitor_name, visitor_email):
    # 1. Setup your email details
    msg = EmailMessage()
    
    # Updated message to include the visitor's email address
    msg.set_content(f"{visitor_name} ({visitor_email}) looked at your script.")
    
    msg['Subject'] = 'New Portfolio Interaction'
    msg['From'] = "jodiebdavidson@gmail.com"  # Your "sender" email
    msg['To'] = "jodiebdavidson@gmail.com"    # Your recipient email

    # 2. Connect to the mail server
    try:
        server = smtplib.SMTP('smtp.gmail.com', 587)
        server.starttls()  # Secure the connection
        
        # IMPORTANT: Use a Google "App Password" here, not your regular login password
        server.login("jodiebdavidson@gmail.com", "your_app_password_here")
        
        server.send_message(msg)
        server.quit()
        print("Success: Notification sent!")
    except Exception as e:
        print(f"Error: Could not send email. {e}")

# 3. Ask the user for their details
name = input("Enter your first name: ")
email = input("Enter your email address: ")

print(f"Hello, {name}!")

# 4. Execute the notification
send_notification(name, email)
