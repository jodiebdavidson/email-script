import smtplib
from email.message import EmailMessage

def send_notification(visitor_name, visitor_email):
    msg = EmailMessage()
    msg.set_content(f"{visitor_name} ({visitor_email}) looked at your script.")
    
    msg['Subject'] = 'New Portfolio Interaction'
    
    # These labels are for the email header
    msg['From'] = "sender@example.com" 
    msg['To'] = "crystalforest6@gmail.com" 

    try:
        # Connect to Mailtrap Sandbox (Dummy Server)
        server = smtplib.SMTP('sandbox.smtp.mailtrap.io', 2525)
        server.starttls()
        
        # Replace these with the credentials from your Mailtrap "SMTP Settings" tab
        server.login("PASTE_YOUR_MAILTRAP_USERNAME", "PASTE_YOUR_MAILTRAP_PASSWORD")
        
        server.send_message(msg)
        server.quit()
        print("Success: Test email sent to Mailtrap inbox!")
    except Exception as e:
        print(f"Error: {e}")

# Ask for user details
name = input("Enter your name: ")
email = input("Enter your email: ")

# Run the notification
send_notification(name, email)
