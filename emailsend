import smtplib
from email.message import EmailMessage

def send_notification(visitor_name, visitor_email):
    msg = EmailMessage()
    msg.set_content(f"{visitor_name} ({visitor_email}) looked at your script.")
    
    msg['Subject'] = 'New Portfolio Interaction'
    
    # SENDER: Put in your email here
    msg['From'] = "YOUR_DEV_EMAIL@gmail.com" 
    
    # RECIPIENT: The random/secondary address you provided
    msg['To'] = "crystalforest6@gmail.com" 

    try:
        server = smtplib.SMTP('smtp.gmail.com', 587)
        server.starttls()
        
        # You still need an App Password for whichever account is the SENDER
        server.login("YOUR_DEV_EMAIL@gmail.com", "your_app_password_here")
        
        server.send_message(msg)
        server.quit()
        print("Success: Email sent to crystalforest6@gmail.com")
    except Exception as e:
        print(f"Error: {e}")

name = input("Enter name: ")
email = input("Enter email: ")
send_notification(name, email)
